# Backend Environment Configuration
# Copy this to .env and adjust values as needed

# Directory containing the .h5 model files (relative to backend/)
MODEL_DIR=../

# Local history file path
HISTORY_FILE=data/history.json

# Max upload size in megabytes
MAX_UPLOAD_MB=50

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: MongoDB connection string (leave empty to use JSON history)
# MONGODB_URI=mongodb://localhost:27017/radiai

# Google Gemini API Key (for AI explanation layer)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
